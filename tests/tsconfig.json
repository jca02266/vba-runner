{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../test-libs/**/*.ts"]
}
