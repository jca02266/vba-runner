{
  "name": "vba-runner",
  "displayName": "VBA Runner",
  "description": "VBA Runner with LSP support, testing integration, and interactive debugging",
  "version": "0.1.0",
  "type": "module",
  "publisher": "vba-runner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jca02266/vba-runner"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vba",
        "aliases": [
          "VBA",
          "vba"
        ],
        "extensions": [
          ".bas",
          ".bas",
          ".cls",
          ".frm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vba",
        "scopeName": "source.bas",
        "path": "./syntaxes/vba.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vba-runner.showCallGraph",
        "title": "Show Call Graph",
        "category": "VBA"
      },
      {
        "command": "vba-runner.showInCallGraph",
        "title": "Show in Call Graph",
        "category": "VBA"
      },
      {
        "command": "vba-runner.introduceVariable",
        "title": "Introduce Variable",
        "category": "Refactor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vba-runner.showCallGraph",
          "when": "resourceLangId == vba",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "vba-runner.showCallGraph",
          "when": "resourceLangId == vba"
        },
        {
          "command": "vba-runner.showInCallGraph",
          "when": "false"
        }
      ]
    },
    "debuggers": [
      {
        "type": "vba",
        "label": "VBA Debugger",
        "languages": [
          "vba"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .bas file to debug",
                "default": "${file}"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "vba",
            "request": "launch",
            "name": "Debug VBA",
            "program": "${file}"
          }
        ]
      }
    ],
    "configurationDefaults": {
      "[vba]": {
        "editor.stickyScroll.defaultModel": "foldingProviderModel"
      }
    },
    "mcpServers": {
      "vba-runner": {
        "command": "node",
        "args": ["${extensionPath}/dist/mcp-server.cjs"]
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:extension",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.cjs --platform=node --external:vscode",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --outfile=dist/mcp-server.cjs --platform=node --format=cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run build:extension && vsce package --no-dependencies",
    "publish": "vsce publish",
    "test-gen": "esbuild test-libs/vba-test-generator.ts --bundle --outfile=dist/test-generator.cjs --platform=node && node dist/test-generator.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vscode/vsce": "^2.6.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.23.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
