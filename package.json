{
  "name": "vba-runner",
  "version": "0.1.0",
  "private": true,
  "description": "VBA execution engine (lexer/parser/evaluator) and monorepo for the VBA Runner npm package, VS Code extension, and Web UI playground",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jca02266/vba-runner"
  },
  "scripts": {
    "test": "./run_all_tests.sh",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "build": "npm run build --prefix build/runner && npm run build --prefix build/extension && npm run build --prefix build/playground && npm run build --prefix build/extractor",
    "build:runner": "npm run build --prefix build/runner",
    "build:extension": "npm run build --prefix build/extension",
    "build:playground": "npm run build --prefix build/playground",
    "build:extractor": "npm run build --prefix build/extractor",
    "package:extension": "npm run package --prefix build/extension",
    "vba-runner": "node scripts/wrapper.mjs test-libs/vba-runner-cli.ts",
    "vba-extractor": "node scripts/wrapper.mjs tools/extractor/vba-extractor.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vscode/l10n": "^0.0.18",
    "@vscode/vsce": "^2.6.0",
    "autoprefixer": "^10.4.24",
    "cfb": "^1.2.2",
    "esbuild": "^0.23.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "iconv-lite": "^0.6.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
