{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run VBA TypeScript Test",
      "type": "shell",
      "command": "./node_modules/.bin/esbuild ${file} --bundle --outfile=${fileDirname}/${fileBasenameNoExtension}.cjs --platform=node && node ${fileDirname}/${fileBasenameNoExtension}.cjs",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: build:extension",
      "type": "npm",
      "script": "build:extension",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: build:extension:web",
      "type": "npm",
      "script": "build:extension:web",
      "problemMatcher": []
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "problemMatcher": []
    }
  ]
}
