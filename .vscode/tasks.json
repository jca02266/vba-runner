{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run VBA TypeScript Test",
      "type": "shell",
      "command": "npx tsx ${file}",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: build:extension",
      "type": "npm",
      "script": "build:extension",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: build:extension:web",
      "type": "npm",
      "script": "build:extension:web",
      "problemMatcher": []
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "problemMatcher": []
    },
    {
      "label": "setup: vba-sample",
      "type": "shell",
      "command": "npm run build:lib && npm run build:bin && npm pack && npm install --prefix ./vba-sample $(ls -t vba-runner-*.tgz | head -1) && npm run build:extension",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
