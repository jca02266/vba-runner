{
  "name": "vba-runner",
  "displayName": "VBA Runner",
  "description": "VBA Runner with LSP support, testing integration, and interactive debugging",
  "version": "0.2.0",
  "publisher": "jca02266",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jca02266/vba-runner"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.cjs",
  "l10n": "./l10n/bundle.l10n.json",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vba",
        "aliases": [
          "VBA",
          "vba"
        ],
        "extensions": [
          ".bas",
          ".cls",
          ".frm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vba",
        "scopeName": "source.bas",
        "path": "./syntaxes/vba.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vba-runner.showCallGraph",
        "title": "Show Call Graph",
        "category": "VBA"
      },
      {
        "command": "vba-runner.showInCallGraph",
        "title": "Show in Call Graph",
        "category": "VBA"
      },
      {
        "command": "vba-runner.debugProcedure",
        "title": "Debug Procedure",
        "category": "VBA"
      },
      {
        "command": "vba-runner.introduceVariable",
        "title": "Introduce Variable",
        "category": "Refactor"
      },
      {
        "command": "vba-runner.generateMocks",
        "title": "Generate Mock Stubs",
        "category": "VBA"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vba-runner.showCallGraph",
          "when": "resourceLangId == vba",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "vba-runner.showCallGraph",
          "when": "resourceLangId == vba"
        },
        {
          "command": "vba-runner.showInCallGraph",
          "when": "false"
        },
        {
          "command": "vba-runner.generateMocks",
          "when": "resourceLangId == vba"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "vba"
      }
    ],
    "debuggers": [
      {
        "type": "vba",
        "label": "VBA Debugger",
        "languages": [
          "vba"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .bas file to debug",
                "default": "${file}"
              },
              "entryPoint": {
                "type": "string",
                "description": "Name of the Sub/Function to run (omit to auto-detect: first Sub, or first Function as fallback)"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "vba",
            "request": "launch",
            "name": "Debug VBA",
            "program": "${file}"
          }
        ]
      }
    ],
    "configuration": {
      "title": "VBA Runner",
      "properties": {
        "vba-runner.lint.enabled": {
          "type": "boolean",
          "default": false,
          "description": "VBA lint 警告（VBA001〜 等のコード付き診断）をすべて有効にする。lint.enabledCodes が設定されている場合はそちらが優先される。パーサー構文エラーは常に表示される"
        },
        "vba-runner.lint.enabledCodes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "有効にする lint コードを個別指定する（例: [\"VBA009\"]）。空の場合は lint.enabled の値に従う"
        },
        "vba-runner.editor.autoLineContinuation": {
          "type": "boolean",
          "default": true,
          "description": "式の途中で Enter を押したとき行継続文字 _ を自動挿入する（editor.formatOnType が有効な場合のみ動作）"
        },
        "vba-runner.editor.autoKeywordCasing": {
          "type": "boolean",
          "default": true,
          "description": "キーワードをスペース・Tab・Enter で確定したとき正規のケース（If, WithEvents 等）に自動補正する（VBE と同じ挙動。editor.formatOnType が有効な場合のみ動作）"
        },
        "vba-runner.editor.autoParentheses": {
          "type": "boolean",
          "default": true,
          "description": "Sub/Function/Property の宣言行で Enter を押したとき、括弧がなければ () を自動挿入する（VBE と同じ挙動。editor.formatOnType が有効な場合のみ動作）"
        },
        "vba-runner.editor.autoEndBlock": {
          "type": "boolean",
          "default": true,
          "description": "Sub/Function/Property の宣言行で Enter を押したとき、対応する End Sub/End Function/End Property がなければ自動挿入する（VBE と同じ挙動。editor.formatOnType が有効な場合のみ動作）"
        },
        "vba-runner.test.location": {
          "type": "string",
          "enum": [
            "sameFile",
            "separateFile"
          ],
          "enumDescriptions": [
            "Test_メソッド名 を同じ .bas ファイル末尾に追記する",
            "<ファイル名>Test.bas を作成してテストを追記する"
          ],
          "description": "generateTest コマンドでテストスタブを追加する場所。未設定の場合は初回実行時に選択を求めます。"
        }
      }
    },
    "configurationDefaults": {
      "[vba]": {
        "editor.stickyScroll.defaultModel": "foldingProviderModel",
        "editor.formatOnType": true,
        "editor.acceptSuggestionOnEnter": "off"
      }
    }
  },
  "scripts": {
    "build": "esbuild ../../src/extension.ts --bundle --outfile=dist/extension.cjs --platform=node --external:vscode --define:import.meta.dirname=__dirname --define:import.meta.url=__filename && esbuild ../../src/lsp/debug-worker.ts --bundle --outfile=dist/debug-worker.cjs --platform=node --define:import.meta.dirname=__dirname --define:import.meta.url=__filename",
    "package": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\" && npm run build && vsce package --no-dependencies",
    "publish": "export $(cat .env | grep -v '^#' | xargs) && vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.6.0"
  }
}
